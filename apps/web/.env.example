# All variables here are OPTIONAL. The app builds and runs with NONE of them set.

# Canonical site URL — used only to make Open Graph / Twitter share previews use
# absolute URLs. If unset, the app falls back to Vercel's VERCEL_URL, then a
# default. Set this to your production domain for clean social previews.
# NEXT_PUBLIC_SITE_URL=https://foodala.vercel.app

# Supabase project credentials.
#
# The build does NOT require these — the site still compiles and deploys without
# them, and the catalog + admin orders run on local mock data. They ARE required
# for the live feature that uses Supabase:
#   • Restaurant partner applications (/partners/apply submit +
#     /admin/restaurants/applications review).
# Run apps/web/supabase/migrations/0002_restaurant_applications.sql first, then
# set the two values below.
#
# NEXT_PUBLIC_* values are exposed to the browser. The anon key is safe to ship
# only with Row Level Security enabled (the migration enables it). NEVER put the
# service_role key in a NEXT_PUBLIC_ variable.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
