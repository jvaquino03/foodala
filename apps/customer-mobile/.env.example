# Supabase project credentials.
# Copy this file to ".env" and fill in your own values.
# These MUST be prefixed with EXPO_PUBLIC_ to be readable by the Expo client at runtime.
# The anon key is safe to ship in a client app ONLY when Row Level Security is enabled
# (this project's migration enables RLS). Never put the service_role key here.

EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
