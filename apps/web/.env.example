# All variables here are OPTIONAL. The app builds and runs with NONE of them set.

# Canonical site URL — used only to make Open Graph / Twitter share previews use
# absolute URLs. If unset, the app falls back to Vercel's VERCEL_URL, then a
# default. Set this to your production domain for clean social previews.
# NEXT_PUBLIC_SITE_URL=https://foodala.vercel.app

# Supabase project credentials (OPTIONAL).
#
# The web app runs in MOCK-DATA mode by default and needs NO env vars to start —
# just `npm install && npm run dev`. These are only required when you wire the
# site/admin to a real Supabase backend (the same schema as
# apps/customer-mobile/supabase/migrations).
#
# NEXT_PUBLIC_* values are exposed to the browser. The anon key is safe to ship
# only when Row Level Security is enabled (the migration enables it). Never put
# the service_role key in a NEXT_PUBLIC_ variable.

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
